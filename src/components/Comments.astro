---
const { slug } = Astro.props;
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div class="mt-16 pt-8 border-t border-border-subtle" id="comments-section">
    <h3 class="text-2xl font-bold mb-6 text-text-primary">Comentarios</h3>

    <!-- List of comments -->
    <div id="comments-list" class="space-y-6 mb-10">
        <p class="text-text-muted italic" id="loading-msg">Cargando comentarios...</p>
    </div>

    <!-- Add Comment Form -->
    <div class="bg-bg-card p-6 rounded-lg border border-border-subtle">
        <h4 class="text-lg font-bold mb-4 text-text-primary">Deja un comentario</h4>
        <form id="comment-form" class="space-y-4">
            <div>
                <label for="author" class="block text-sm font-medium text-text-secondary mb-1">Nombre</label>
                <input 
                    type="text" 
                    id="author" 
                    name="author" 
                    required 
                    class="w-full px-4 py-2 rounded-md bg-bg-canvas border border-border-input text-text-primary focus:outline-none focus:ring-2 focus:ring-accent"
                    placeholder="Tu nombre"
                />
            </div>
            
            <div>
                <label for="content" class="block text-sm font-medium text-text-secondary mb-1">Comentario</label>
                <textarea 
                    id="content" 
                    name="content" 
                    required 
                    rows="4" 
                    class="w-full px-4 py-2 rounded-md bg-bg-canvas border border-border-input text-text-primary focus:outline-none focus:ring-2 focus:ring-accent resize-none"
                    placeholder="Escribe tu opinión..."
                ></textarea>
            </div>

            <!-- Turnstile Widget -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAAACOf1Tx6fg28y6Ba"></div>

            <button 
                type="submit" 
                class="px-6 py-2 bg-accent text-white font-bold rounded-md hover:bg-accent/90 transition disabled:opacity-50 disabled:cursor-not-allowed"
                id="submit-btn"
            >
                Publicar comentario
            </button>
            <p id="form-msg" class="text-sm mt-2 hidden"></p>
        </form>
    </div>
</div>

<script define:vars={{ slug }}>
    const commentsList = document.getElementById('comments-list');
    const form = document.getElementById('comment-form');
    const msg = document.getElementById('form-msg');
    const submitBtn = document.getElementById('submit-btn');

    // Fetch comments
    async function loadComments() {
        try {
            const res = await fetch(`/api/comments/${slug}`);
            if (!res.ok) throw new Error('Failed to load');
            const comments = await res.json();
            
            commentsList.innerHTML = '';
            
            if (comments.length === 0) {
                commentsList.innerHTML = '<p class="text-text-muted">Sé el primero en comentar.</p>';
                return;
            }

            comments.forEach(comment => {
                const date = new Date(comment.created_at * 1000).toLocaleDateString('es-ES', {
                    year: 'numeric', month: 'long', day: 'numeric'
                });

                const div = document.createElement('div');
                div.className = 'border-b border-border-subtle pb-4 last:border-0';
                div.innerHTML = `
                    <div class="flex items-center justify-between mb-2">
                        <span class="font-bold text-text-primary">${escapeHtml(comment.author)}</span>
                        <span class="text-xs text-text-muted">${date}</span>
                    </div>
                    <p class="text-text-secondary whitespace-pre-wrap">${escapeHtml(comment.content)}</p>
                `;
                commentsList.appendChild(div);
            });
        } catch (e) {
            commentsList.innerHTML = '<p class="text-red-500">Error al cargar comentarios.</p>';
        }
    }

    // Post comment
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.innerText = 'Enviando...';
        msg.className = 'text-sm mt-2 hidden';

        const author = document.getElementById('author').value;
        const content = document.getElementById('content').value;
        
        // Get Turnstile token
        const formData = new FormData(form);
        const token = formData.get('cf-turnstile-response');

        try {
            const res = await fetch(`/api/comments/${slug}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ author, content, token })
            });

            if (res.ok) {
                form.reset();
                msg.textContent = '¡Comentario publicado!';
                msg.className = 'text-sm mt-2 text-green-500';
                loadComments(); // Refresh list
            } else {
                throw new Error('Error posting');
            }
        } catch (e) {
            msg.textContent = 'Hubo un error al enviar el comentario.';
            msg.className = 'text-sm mt-2 text-red-500';
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = 'Publicar comentario';
        }
    });

    function escapeHtml(text) {
        if (!text) return text;
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Initial load
    loadComments();
</script>
