---
const { slug, lang = "es" } = Astro.props;
import { useTranslations } from "../i18n/ui";

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const t = useTranslations(lang);

// Pass translations to client-side
const clientStrings = {
    loading: t("comments.loading"),
    empty: t("comments.empty"),
    loadError: t("comments.loadError"),
    submitting: t("comments.submitting"),
    success: t("comments.success"),
    error: t("comments.error"),
    submit: t("comments.submit"),
    locale: lang === "en" ? "en-US" : "es-ES"
};
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div class="mt-16 pt-8 border-t border-border-subtle" id="comments-section">
    <h3 class="text-2xl font-bold mb-6 text-text-primary">{t('comments.title')}</h3>

    <!-- List of comments -->
    <div id="comments-list" class="space-y-6 mb-10">
        <p class="text-text-muted italic" id="loading-msg">{t('comments.loading')}</p>
    </div>

    <!-- Add Comment Form -->
    <div class="bg-gradient-to-br from-bg-card to-bg-subtle p-8 rounded-2xl border border-border-subtle shadow-lg">
        <h4 class="text-xl font-bold mb-6 text-text-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            {t('comments.leave')}
        </h4>
        <form id="comment-form" class="space-y-6">
            <div class="space-y-2">
                <label for="author" class="text-sm font-bold text-text-muted uppercase tracking-wider ml-1">{t('comments.name')}</label>
                <div class="relative group">
                    <input 
                        type="text" 
                        id="author" 
                        name="author" 
                        required 
                        class="w-full pl-4 pr-4 py-3 rounded-lg bg-bg-canvas border border-border-input text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all shadow-sm group-hover:border-accent/50"
                        placeholder={t('comments.namePlaceholder')}
                    />
                </div>
            </div>
            
            <div class="space-y-2">
                <label for="content" class="text-sm font-bold text-text-muted uppercase tracking-wider ml-1">{t('comments.comment')}</label>
                <div class="relative group">
                    <textarea 
                        id="content" 
                        name="content" 
                        required 
                        rows="4" 
                        class="w-full pl-4 pr-4 py-3 rounded-lg bg-bg-canvas border border-border-input text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all shadow-sm resize-y min-h-[120px] group-hover:border-accent/50"
                        placeholder={t('comments.commentPlaceholder')}
                    ></textarea>
                </div>
            </div>

            <!-- Turnstile Widget -->
            <div class="cf-turnstile" data-sitekey={siteKey}></div>

            <div class="flex items-center justify-between pt-2">
                 <p id="form-msg" class="text-sm hidden"></p>
                <button 
                    type="submit" 
                    class="px-8 py-3 bg-accent text-white font-bold rounded-lg shadow-md hover:shadow-xl hover:bg-accent/90 hover:-translate-y-0.5 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
                    id="submit-btn"
                >
                    {t('comments.submit')}
                </button>
            </div>
        </form>
    </div>
</div>

<script define:vars={{ slug, clientStrings }}>
    const commentsList = document.getElementById('comments-list');
    const form = document.getElementById('comment-form');
    const msg = document.getElementById('form-msg');
    const submitBtn = document.getElementById('submit-btn');

    // Fetch comments
    async function loadComments() {
        try {
            const res = await fetch(`/api/comments/${slug}`);
            if (!res.ok) throw new Error('Failed to load');
            const comments = await res.json();
            
            commentsList.innerHTML = '';
            
            if (comments.length === 0) {
                commentsList.innerHTML = `<p class="text-text-muted">${clientStrings.empty}</p>`;
                return;
            }

            comments.forEach((comment, index) => {
                const date = new Date(comment.created_at * 1000).toLocaleDateString(clientStrings.locale, {
                    year: 'numeric', month: 'long', day: 'numeric'
                });

                // Get initials for avatar
                const initials = comment.author
                    .split(' ')
                    .map(n => n[0])
                    .join('')
                    .substring(0, 2)
                    .toUpperCase();

                const div = document.createElement('div');
                div.className = 'bg-bg-card p-5 rounded-lg border border-border-subtle shadow-sm flex gap-4 transition-transform hover:-translate-y-0.5 duration-300 animate-fade-in-up';
                div.style.animationDelay = `${index * 100}ms`; // Stagger effect
                
                div.innerHTML = `
                    <div class="shrink-0 w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center text-accent font-bold text-sm select-none">
                        ${escapeHtml(initials)}
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-bold text-text-primary text-base">${escapeHtml(comment.author)}</span>
                            <span class="text-xs text-text-muted font-medium bg-bg-subtle px-2 py-1 rounded-md border border-border-subtle">${date}</span>
                        </div>
                        <p class="text-text-secondary whitespace-pre-wrap text-sm leading-relaxed">${escapeHtml(comment.content)}</p>
                    </div>
                `;
                commentsList.appendChild(div);
            });
        } catch (e) {
            commentsList.innerHTML = `<p class="text-red-500">${clientStrings.loadError}</p>`;
        }
    }

    // Post comment
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.innerText = clientStrings.submitting;
        msg.className = 'text-sm mt-2 hidden';

        const author = document.getElementById('author').value;
        const content = document.getElementById('content').value;
        
        // Get Turnstile token
        const formData = new FormData(form);
        const token = formData.get('cf-turnstile-response');

        try {
            const res = await fetch(`/api/comments/${slug}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ author, content, token })
            });

            if (res.ok) {
                form.reset();
                msg.textContent = clientStrings.success;
                msg.className = 'text-sm mt-2 text-green-500';
                loadComments(); // Refresh list
            } else {
                throw new Error('Error posting');
            }
        } catch (e) {
            msg.textContent = clientStrings.error;
            msg.className = 'text-sm mt-2 text-red-500';
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = clientStrings.submit;
        }
    });

    function escapeHtml(text) {
        if (!text) return text;
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Initial load
    loadComments();
</script>
