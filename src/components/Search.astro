---
/**
 * Componente de búsqueda integrado con Pagefind para indexación estática.
 */
---

{/* Contenedor donde PagefindUI montará la interfaz de búsqueda */}
<div id="search" class="ml-auto relative"></div>

<script is:inline>
    /**
     * Inicializa la interfaz de búsqueda de Pagefind cuando el DOM está listo.
     * @sideEffects
     * - Instancia PagefindUI en el elemento #search
     * - Configura opciones de visualización de resultados
     */
    window.addEventListener("DOMContentLoaded", () => {
        // 1. Esperar a que el DOM esté completamente cargado
        // 2. Instanciar PagefindUI con configuración personalizada
        new PagefindUI({
            element: "#search", // Selector del contenedor donde se montará la UI
            showSubResults: true, // Mostrar resultados jerárquicos por sección
        });
    });
</script>

<style is:global>
    /* Variables CSS para personalizar la interfaz de Pagefind */
    .pagefind-ui {
        --pagefind-ui-scale: 0.8;
        --pagefind-ui-primary: #b45309;
        --pagefind-ui-text: #44403c;
        --pagefind-ui-background: #ffffff;
        --pagefind-ui-border: #e7e5e4;
        --pagefind-ui-tag: #f5f5f4;
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-font: sans-serif;
    }

    /* Ocultar etiqueta de búsqueda por defecto: el placeholder del input es suficiente */
    .pagefind-ui .pagefind-ui__search-label {
        display: none;
    }

    /* Ajustar padding y peso de fuente del campo de entrada */
    .pagefind-ui .pagefind-ui__search-input {
        font-weight: normal;
        padding-left: 1rem;
    }

    /* Estilos del contenedor de resultados (dropdown) */
    .pagefind-ui .pagefind-ui__drawer {
        position: absolute;
        left: 0;
        right: 0;
        top: 100%;
        margin-top: 10px;
        z-index: 100;
        background: white;
        border: 1px solid #e7e5e4;
        border-radius: 8px;
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        max-height: 400px;
        overflow-y: auto;
        padding: 10px;
    }
</style>

{/* Carga de recursos externos de Pagefind: CSS y JS de la UI */}
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" is:inline />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
