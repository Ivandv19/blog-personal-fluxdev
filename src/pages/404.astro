---
import Layout from "../layouts/Layout.astro";
import { useTranslations, defaultLang } from "../i18n/ui";

const lang = Astro.params.lang || defaultLang;
const t = useTranslations(lang as any);
---

<Layout title="404: Not Found" description="Page not found">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center px-4">
    <h1 class="text-9xl font-extrabold text-accent mb-4">404</h1>
    <h2 class="text-3xl font-bold text-text-primary mb-6">Página no encontrada</h2>
    <p class="text-text-muted text-lg mb-8 max-w-md">
      Lo sentimos, no pudimos encontrar la página que estás buscando. Es posible que haya sido movida o eliminada.
    </p>
    
    <a href="/" class="px-6 py-3 bg-accent text-white font-bold rounded-full hover:bg-accent/90 transition-colors shadow-lg">
      Volver al inicio
    </a>
  </div>
</Layout>
