---
import Layout from '../../layouts/Layout.astro';

// 1. Función obligatoria para generar rutas estáticas (SSG)
export async function getStaticPaths() {
  // Buscamos todos los posts
  const allPosts = await Astro.glob('../blog/*.md');

  // Sacamos todas las etiquetas únicas (Set elimina duplicados)
  const uniqueTags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];

  // Devolvemos una ruta por cada etiqueta encontrada
  return uniqueTags.map((tag) => {
    // Filtramos los posts que tengan esa etiqueta
    const filteredPosts = allPosts.filter((post) => post.frontmatter.tags?.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

// 2. Aquí recibimos los datos de la URL actual
const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`Artículos sobre ${tag}`}>
  <div class="py-10">
    
    <div class="mb-10 border-b border-stone-200 pb-4">
      <p class="text-sm text-stone-500 uppercase tracking-widest font-bold">Explorando</p>
      <h1 class="text-4xl font-bold text-stone-800 capitalize">
        #{tag}
      </h1>
    </div>

    <ul class="grid gap-8">
      {posts.map((post) => (
        <li class="bg-white p-6 rounded-lg shadow-sm border border-stone-100">
            <a href={post.url} class="block group">
                <h2 class="text-2xl font-bold text-stone-800 group-hover:text-amber-700 transition">
                    {post.frontmatter.title}
                </h2>
                <p class="text-stone-600 mt-2 line-clamp-2">{post.frontmatter.description}</p>
                <span class="text-sm font-bold text-amber-700 mt-4 block">Leer artículo &rarr;</span>
            </a>
        </li>
      ))}
    </ul>
    
    <div class="mt-12">
        <a href="/" class="text-stone-500 hover:text-stone-800 underline underline-offset-4">
            &larr; Volver al inicio
        </a>
    </div>

  </div>
</Layout>