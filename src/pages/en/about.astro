---
// Pagina "Sobre mi" (Ingles)
import Layout from "../../layouts/Layout.astro";

const lang = "en";
---

<Layout title="About | Flux Blog" lang={lang}>
    <section class="max-w-3xl mx-auto py-12 prose prose-stone dark:prose-invert">
        <h1>About Me</h1>
        <p>
            Hi, I'm <strong>Flux</strong>. Welcome to my personal blog.
        </p>
        <p>
            I'm a developer passionate about technology, clean code, and software architecture.
            In this space, I share my learnings, tutorials, and thoughts on the world of web development and beyond.
        </p>
        <p>
            My goal is to document my journey and help other developers improve their skills.
        </p>
    </section>
</Layout>
