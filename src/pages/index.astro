---
import Layout from '../layouts/Layout.astro';

const allPosts = await Astro.glob('./blog/*.md');

const uniqueTags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];

const postsOrdenados = allPosts.sort((a, b) => 
    new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<Layout title="Inicio | Mi Blog">
    <section class="py-8 md:py-12">
        
        <h1 class="text-3xl md:text-4xl font-extrabold text-stone-900 mb-6 tracking-tight">
            Desarrollo de software, crecimiento personal, tutoriales y <span class="text-amber-700">un poco de mí.</span>
        </h1>
        
        <div class="mb-10 max-w-2xl">
            <p class="text-lg text-stone-600 leading-relaxed mb-6">
                ¡Bienvenido a mi blog! Estaré compartiendo artículos sobre desarrollo de software, tecnología y productividad. Mi objetivo es ayudarte a crecer tanto profesional como personalmente con base en mis estudios, experiencia y aprendizajes.
            </p>

            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-900">
                <p>⚠️ <strong>Nota:</strong> Esta página web es nueva, por ende es posible que tenga algunos bugs visuales, artículos que no cargan o mal rendimiento en general. No te preocupes si ves errores, estoy trabajando en ello :)</p>
            </div>
        </div>

        {uniqueTags.length > 0 && (
            <div class="mb-12 border-b border-stone-200 pb-8">
                <p class="text-xs font-bold text-stone-400 uppercase tracking-wider mb-3">Temas Populares</p>
                <div class="flex flex-wrap gap-3">
                    {uniqueTags.map((tag) => (
                        <a 
                            href={`/etiquetas/${tag}`} 
                            class="bg-white border border-stone-200 text-stone-600 px-4 py-2 rounded-full text-sm font-medium hover:border-amber-400 hover:text-amber-700 hover:shadow-sm transition"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            </div>
        )}

        <div class="grid gap-6 md:gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            {postsOrdenados.map((post) => (
                <article class="bg-white p-6 rounded-lg shadow-sm border border-stone-100 hover:border-amber-300 hover:shadow-md transition duration-300 flex flex-col h-full">
                    
                    <div class="flex justify-between items-center mb-3">
                        <div class="flex items-center gap-2 text-xs text-stone-400 font-medium">
                            <span>{post.frontmatter.date}</span>
                            <span>•</span>
                            <span class="text-amber-700 font-bold bg-amber-50 px-2 py-0.5 rounded-full">
                                {Math.ceil(post.frontmatter.minutesRead || 1)} min
                            </span>
                        </div>
                    </div>

                    <h2 class="text-xl md:text-2xl font-bold mb-3 text-stone-800 leading-tight">
                        <a href={post.url} class="hover:text-amber-700 transition-colors">
                            {post.frontmatter.title}
                        </a>
                    </h2>
                    
                    <p class="text-stone-600 mb-6 line-clamp-3 flex-grow text-sm md:text-base">
                        {post.frontmatter.description}
                    </p>

                    <a href={post.url} class="text-sm font-bold text-stone-900 hover:text-amber-700 flex items-center gap-1 group mt-auto">
                        Leer más 
                        <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                    </a>
                </article>
            ))}
        </div>
    </section>
</Layout>