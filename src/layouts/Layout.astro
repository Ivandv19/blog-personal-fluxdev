---
import "../styles/global.css";
import Search from "../components/Search.astro";
import BaseHead from "../components/BaseHead.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import LanguagePicker from "../components/LanguagePicker.astro";
import { useTranslations, defaultLang } from "../i18n/ui";

const {
	title,
	description = "Un blog sobre desarrollo y tecnología.",
	image,
	type = "website",
	publishDate,
} = Astro.props;

const lang = Astro.params.lang || defaultLang;
const t = useTranslations(lang as any);
---

<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead title={title} description={description} image={image} type={type} publishDate={publishDate} />
        <script is:inline>
            // 1. Theme Check
            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // 2. Language Auto-Redirect (Only on root '/')
            // Checks if user prefers English and hasn't manually selected Spanish (optional constraint)
            // Ideally we check if we are at root and user has 'en' preference
            if (window.location.pathname === '/' && !localStorage.getItem('lang-preference')) {
                const userLang = navigator.language || navigator.userLanguage;
                if (userLang.startsWith('en')) {
                    // Redirect to English
                    window.location.href = '/en/';
                }
            }
        </script>
    </head>
    <body class="bg-bg-canvas text-text-primary font-sans antialiased flex flex-col min-h-screen transition-colors duration-300">
        
        <header class="border-b border-border-subtle bg-bg-canvas/90 sticky top-0 backdrop-blur-sm z-40 transition-colors duration-300">
            <nav class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center gap-4">
                <a href={`/${lang === 'es' ? '' : lang}`} class="font-bold text-xl tracking-tight hover:text-accent transition-colors shrink-0">
                    Flux
                </a>
                
                <div class="flex-1 max-w-xs relative flex justify-end items-center gap-4">
                     <div class="w-full max-w-[200px]">
                        <Search />
                     </div>
                </div>

                <div class="flex items-center gap-4 shrink-0">
                    <div class="hidden sm:block text-sm font-medium">
                        <a href={`/${lang === 'es' ? '' : lang}`} class="hover:text-accent transition-colors">{t('nav.home')}</a>
                    </div>
                    <LanguagePicker />
                    <ThemeToggle />
                </div>
            </nav>
        </header>

        <main class="w-full max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex-grow">
            <slot /> 
        </main>

        <footer class="border-t border-border-subtle mt-auto py-8 text-center text-text-muted text-sm transition-colors duration-300">
            <p>&copy; 2025 - {t('footer.copyright')}</p>
        </footer>

    </body>
</html>