---
import '../styles/global.css';
import Search from '../components/Search.astro';
import BaseHead from '../components/BaseHead.astro';

const { 
    title, 
    description = "Un blog sobre desarrollo y tecnología.",
    image
} = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={title} description={description} image={image} />
    </head>
    <body class="bg-stone-50 text-stone-800 font-sans antialiased flex flex-col min-h-screen">
        
        <header class="border-b border-stone-200 bg-stone-50/90 sticky top-0 backdrop-blur-sm z-40">
            <nav class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center gap-4">
                <a href="/" class="font-bold text-xl tracking-tight hover:text-amber-700 transition-colors shrink-0">
                    Flux
                </a>
                
                <div class="flex-1 max-w-xs relative">
                    <Search />
                </div>

                <div class="hidden sm:block space-x-6 text-sm font-medium shrink-0">
                    <a href="/" class="hover:text-amber-700 transition-colors">Inicio</a>
                </div>
            </nav>
        </header>

        <main class="w-full max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex-grow">
            <slot /> 
        </main>

        <footer class="border-t border-stone-200 mt-auto py-8 text-center text-stone-500 text-sm">
            <p>&copy; 2025 - desarrollado por Flux.</p>
        </footer>

    </body>
</html>