---
import '../styles/global.css';
import Search from '../components/Search.astro';
import BaseHead from '../components/BaseHead.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const { 
    title, 
    description = "Un blog sobre desarrollo y tecnología.",
    image
} = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={title} description={description} image={image} />
        <script is:inline>
            // On page load or when changing themes, best to add inline in `head` to avoid FOUC
            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
    </head>
    <body class="bg-bg-canvas text-text-primary font-sans antialiased flex flex-col min-h-screen transition-colors duration-300">
        
        <header class="border-b border-border-subtle bg-bg-canvas/90 sticky top-0 backdrop-blur-sm z-40 transition-colors duration-300">
            <nav class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center gap-4">
                <a href="/" class="font-bold text-xl tracking-tight hover:text-accent transition-colors shrink-0">
                    Flux
                </a>
                
                <div class="flex-1 max-w-xs relative flex justify-end items-center gap-4">
                     <div class="w-full max-w-[200px]">
                        <Search />
                     </div>
                </div>

                <div class="flex items-center gap-4 shrink-0">
                    <div class="hidden sm:block text-sm font-medium">
                        <a href="/" class="hover:text-accent transition-colors">Inicio</a>
                    </div>
                    <ThemeToggle />
                </div>
            </nav>
        </header>

        <main class="w-full max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex-grow">
            <slot /> 
        </main>

        <footer class="border-t border-border-subtle mt-auto py-8 text-center text-text-muted text-sm transition-colors duration-300">
            <p>&copy; 2025 - desarrollado por Flux.</p>
        </footer>

    </body>
</html>