---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <article class="prose prose-stone dark:prose-invert prose-base md:prose-lg mx-auto mt-6 mb-12 md:mt-10 md:mb-20">
    
    <div class="mb-6">
        <a href="/" class="no-underline inline-flex items-center gap-2 text-sm font-bold text-text-muted hover:text-accent transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 group-hover:-translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Volver al inicio
        </a>
    </div>

    <div class="mb-8 border-b border-border-subtle pb-6">
      <h1 class="mb-4 text-3xl md:text-4xl font-extrabold text-text-primary leading-tight">{frontmatter.title}</h1>
      
      <div class="flex flex-wrap items-center gap-4 mb-4">
        
        <div class="flex items-center gap-2 text-text-muted text-sm font-medium">
             <span>Publicado el {frontmatter.date}</span>
        </div>

        <span class="hidden sm:block text-text-muted">•</span>

        <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent-bg text-accent-text border border-accent/20 text-xs font-bold uppercase tracking-wide shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {Math.ceil(frontmatter.minutesRead || 1)} min lectura
        </div>
      </div>

      {frontmatter.tags && (
          <div class="flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                  <a href={`/etiquetas/${tag}`} class="text-xs bg-bg-subtle text-text-secondary px-2 py-1 rounded hover:bg-bg-subtle/80 hover:text-text-primary transition no-underline font-medium border border-border-subtle">
                      #{tag}
                  </a>
              ))}
          </div>
      )}
    </div>
    
    <slot />
    
  </article>
</Layout>
