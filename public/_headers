# Configuración de headers HTTP para Cloudflare Pages.
# Define políticas de seguridad y estrategias de caché por tipo de recurso.
# Sintaxis: https://developers.cloudflare.com/pages/configuration/headers/

# ─────────────────────────────────────────────────────────────
# SECURITY HEADERS - Aplicados a todas las rutas (*)
# ─────────────────────────────────────────────────────────────
/*
  # Previene clickjacking: bloquea carga del sitio en iframes externos
  X-Frame-Options: DENY
  
  # Previene MIME-sniffing: fuerza al navegador a respetar el Content-Type declarado
  X-Content-Type-Options: nosniff
  
  # Protección XSS básica para navegadores legacy (obsoleto en Chromium, mantener por compatibilidad)
  X-XSS-Protection: 1; mode=block
  
  # Control de información de referencia: envía origen solo en mismas condiciones de seguridad
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Restringe APIs del navegador a solo las necesarias para este sitio
  Permissions-Policy: camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  
  # Fuerza HTTPS por 1 año con inclusión de subdominios y preload para HSTS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Content Security Policy: define fuentes permitidas para cada tipo de recurso
  # - default-src 'self': solo recursos del mismo origen por defecto
  # - script-src: permite scripts propios, inline/eval (necesario para Astro/React), Cloudflare Insights, Turnstile y Umami
  # - style-src: permite estilos propios e inline (necesario para CSS-in-JS y critical CSS)
  # - img-src: permite imágenes propias y data: URLs (para avatares generados)
  # - font-src: permite fuentes propias y data: URLs
  # - connect-src: permite fetch/XHR a origen propio, Cloudflare y Umami
  # - frame-src: permite iframes de Turnstile para validación de captcha
  # - frame-ancestors 'none': previene que el sitio sea embebido (refuerzo de X-Frame-Options)
  # - base-uri/form-action 'self': previene inyección de bases o acciones de formulario maliciosas
  # - object-src 'none': bloquea plugins obsoletos como Flash
  # - upgrade-insecure-requests: fuerza carga HTTPS de recursos HTTP mixtos
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com https://challenges.cloudflare.com https://umami.fluxdv.icu; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://cloudflareinsights.com https://challenges.cloudflare.com https://umami.fluxdv.icu; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests;

# ─────────────────────────────────────────────────────────────
# CACHE HEADERS - Estrategias por tipo de recurso
# Formato: max-age (browser), s-maxage (CDN/edge), immutable si aplica
# ─────────────────────────────────────────────────────────────

# Assets con hash en nombre (JS, CSS): cache largo + immutable porque el contenido no cambia sin cambiar el nombre
/*.js
  Cache-Control: public, max-age=31536000, s-maxage=2592000, immutable

/*.css
  Cache-Control: public, max-age=31536000, s-maxage=2592000, immutable

# Fuentes Web: cache largo, sin immutable porque pueden servir sin hash en algunos casos
/*.woff2
  Cache-Control: public, max-age=31536000, s-maxage=2592000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, s-maxage=2592000, immutable

# Imágenes: cache largo en browser, cache medio en edge (7 días) para permitir actualizaciones sin purga manual
/*.png
  Cache-Control: public, max-age=31536000, s-maxage=604800

/*.jpg
  Cache-Control: public, max-age=31536000, s-maxage=604800

/*.jpeg
  Cache-Control: public, max-age=31536000, s-maxage=604800

/*.svg
  Cache-Control: public, max-age=31536000, s-maxage=604800

/*.webp
  Cache-Control: public, max-age=31536000, s-maxage=604800

/*.ico
  Cache-Control: public, max-age=31536000, s-maxage=604800

# HTML: cache corto en edge (1 hora) para permitir despliegues rápidos, revalidación en browser para contenido fresco
/*.html
  Cache-Control: public, max-age=0, s-maxage=3600, must-revalidate

# Manifest y Service Worker: sin cache para asegurar que actualizaciones de PWA se propaguen inmediatamente
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate