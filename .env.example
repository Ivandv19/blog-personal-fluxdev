# Variables de entorno para Astro (Frontend) y configuración local del Worker.
# Nota: Astro solo expone al cliente las variables con prefijo PUBLIC_.
# Las variables sin prefijo se gestionan exclusivamente en el entorno del servidor/Worker.

# Clave pública de Cloudflare Turnstile para inicialización del widget en cliente.
# Obtener desde Cloudflare Dashboard > Turnstile > Tu sitio > Site key.
# @usage: import.meta.env.PUBLIC_TURNSTILE_SITE_KEY en componentes Astro.
# @security: Segura para exponer en frontend; no permite validación de tokens.
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Clave secreta de Cloudflare Turnstile para validación server-side de tokens.
# @scope: Solo utilizada por el Hono Worker en functions/api/[[route]].ts.
# @note: En desarrollo local, colocar en .dev.vars. En producción, configurar como Secret en Cloudflare Dashboard.
# @security: Nunca exponer en cliente ni commitear en repositorio.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here