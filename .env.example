# Variables de entorno para Astro (Frontend)
# Copia este archivo a .env y pon tus llaves reales

# Turnstile: Clave pública (visible en el cliente)
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Turnstile: Clave secreta (SOLO para el Hono Worker)
# ⚠️ Esta variable va en .dev.vars para desarrollo local
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
